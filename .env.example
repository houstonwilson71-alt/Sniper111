# =============================================================================
# MEME COIN SNIPER — ENVIRONMENT CONFIGURATION
# =============================================================================
# ⚠️  WARNING: When LIVE_TRADING_ENABLED=true, the bot will submit real
#     on-chain transactions and move real funds. Only enable this after
#     testing with small amounts and with your own risk controls.
# =============================================================================

# -----------------------------------------------------------------------------
# Required: Database and cache
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://sniper:sniper@localhost:5432/sniper
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Required: Express session secret
# -----------------------------------------------------------------------------
SESSION_SECRET=change-this-to-a-long-random-string

# -----------------------------------------------------------------------------
# Optional: Live trading safety interlock (must be "true" to submit real trades)
# -----------------------------------------------------------------------------
LIVE_TRADING_ENABLED=false

# -----------------------------------------------------------------------------
# Wallet private keys (used by Rust executors). Prefer environment variables
# for production. The dashboard can also store keys encrypted in the database
# if ENCRYPTION_KEY is set.
# -----------------------------------------------------------------------------
SOLANA_PRIVATE_KEY=
BSC_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Encryption key for database-stored private keys (AES-256-GCM)
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=change-this-to-a-32-byte-or-longer-passphrase

# -----------------------------------------------------------------------------
# Internal API token for executor-to-backend key exchange
# -----------------------------------------------------------------------------
INTERNAL_API_TOKEN=change-this-to-a-long-random-token

# -----------------------------------------------------------------------------
# RPC endpoints
# -----------------------------------------------------------------------------
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Or use Helius: https://mainnet.helius-rpc.com/?api-key=<YOUR_KEY>
HELIUS_API_KEY=

BSC_RPC_URL=https://bsc-dataseed.binance.org/
BSC_WS_URL=
# Or use QuickNode: wss://your-node.quiknode.pro/<KEY>
QUICKNODE_BSC_URL=

# -----------------------------------------------------------------------------
# Trade execution endpoints
# -----------------------------------------------------------------------------
JUPITER_API_URL=https://quote-api.jup.ag/v6
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf/api/v1
BLOXROUTE_AUTH_HEADER=

# -----------------------------------------------------------------------------
# Frontend public URLs
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_WS_URL=ws://localhost:5000/ws
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_BSC_RPC_URL=https://bsc-dataseed.binance.org/
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta
