# Copy to .env and fill in real values before running live trading.

# Safety interlock: keep false until you are ready to risk real funds.
LIVE_TRADING_ENABLED=false

# Global bot enable switch.
BOT_ENABLED=true

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=
SOLANA_PRIVATE_KEY=

# BSC
BSC_RPC_URL=https://data-seed-prebsc-1-s1.bnbchain.org:8545
BSC_WS_URL=
BSC_PRIVATE_KEY=

# DEX / execution
JUPITER_API_URL=https://quote-api.jup.ag/v6
JITO_BLOCK_ENGINE_URL=
JITO_TIP_LAMPORTS=10000
BLOXROUTE_AUTH_HEADER=

# Optional premium feeds
HELIUS_API_KEY=
YELLOWSTONE_ENDPOINT=
YELLOWSTONE_TOKEN=

# Secrets
SESSION_SECRET=change-me-in-production
ENCRYPTION_KEY=change-me-in-production
INTERNAL_API_TOKEN=change-me-in-production
